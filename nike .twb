      <aliases enabled='yes' />
      <column caption='Daily return' datatype='real' name='[Calculation_5896943200575492]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Close]) - LOOKUP(SUM([Close]), -1)) &#10;/ LOOKUP(SUM([Close]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Volatility' datatype='real' name='[Calculation_5896943201783814]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_STDEV(SUM([Close]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Running Max' datatype='real' name='[Calculation_5896943418425353]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MAX(SUM([Close]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Drawdown' datatype='real' name='[Calculation_5896943418540042]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Close]) - [Calculation_5896943418425353]) / [Calculation_5896943418425353]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rolling Volatility (30d)' datatype='real' name='[Calculation_5896943420071947]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_STDEV(&#10;(SUM([Close]) - LOOKUP(SUM([Close]), -1)) &#10;/ LOOKUP(SUM([Close]), -1)&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='High Risk' datatype='string' name='[Calculation_5896943420936205]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_5896943420071947] &gt; WINDOW_AVG([Calculation_5896943420071947])&#10;THEN &quot;High&quot;&#10;ELSE &quot;Normal&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='MA 50' datatype='real' name='[Calculation_5896943422087182]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Close]), -49, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='MA 200' datatype='real' name='[Calculation_5896943422177295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Close]), -199, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Signal' datatype='string' name='[Calculation_5896943423651857]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_5896943422087182] &gt; [Calculation_5896943422177295] THEN &quot;BUY&quot;&#10;ELSE &quot;SELL&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Crossover' datatype='string' name='[Calculation_5896943423741970]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_5896943422087182] &gt; [Calculation_5896943422177295] &#10;AND LOOKUP([Calculation_5896943422087182], -1) &lt;= LOOKUP([Calculation_5896943422177295], -1)&#10;THEN &quot;BUY&quot;&#10;&#10;ELSEIF [Calculation_5896943422087182] &lt; [Calculation_5896943422177295] &#10;AND LOOKUP([Calculation_5896943422087182], -1) &gt;= LOOKUP([Calculation_5896943422177295], -1)&#10;THEN &quot;SELL&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='real' name='[Close]' role='measure' type='quantitative' />
      <column datatype='date' name='[Date]' role='dimension' type='ordinal' />
      <column aggregation='Sum' datatype='integer' name='[Month]' role='dimension' type='ordinal' user:agg-type='Month' user:base-field='Date' user:ui-builder='date-bin-builder'>
